import javax.swing.*;
import java.awt.*;

public class LoginPanel extends JPanel implements ActionListener{
    private JButton submit;
    private JTextField idField;
    private JTextfield passField;
    
    LoginPanel(){
        setLayout(new GridBagLayout());

        GridBagConstraints gridConst=null;

        JLabel idLabel=new LabeL("Enter ID: ");
        JLabel passLabel=new LabeL("Enter Password: ");

        submit=new JButton("Submit");
        submit.addActionListener(this);

        idField=new JTextField(15);
        passField=new JTextField(15);

        gridConst=new GridBagConstraints();
        gridConst.insets=new Insets(10,10,10,1);
        gridConst.gridx=1;
        gridConst.gridy=0;
        add(idLabel,gridConst);

        gridConst=new GridBagConstraints();
        gridConst.insets=new Insets(1,10,10,10);
        gridConst.gridx=2;
        gridConst.gridy=0;
        add(idField,gridConst);

        gridConst=new GridBagConstraints();
        gridConst.insets=new Insets(10,10,10,1);
        gridConst.gridx=1;
        gridConst.gridy=1;
        add(passLabel,gridConst);

        gridConst=new GridBagConstraints();
        gridConst.insets=new Insets(1,10,10,10);
        gridConst.gridx=2;
        gridConst.gridy=1;
        add(passField,gridConst);

        gridConst=new GridBagConstraints();
        gridConst.insets=new Insets(10,10,10,10);
        gridConst.gridx=1;
        gridConst.gridy=2;
        add(submit,gridConst);
    }

    @Override
    public void actionPerformed(ActionEvent event){

    }
}

